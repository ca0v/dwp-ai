# Server
PORT=3000
UPLOADS_DIR=uploads

# AI Provider (OpenAI-compatible)
AI_PROVIDER_URL=https://api.x.ai/v1
AI_API_KEY=your-xai-api-key-here
AI_MODEL=grok-2-vision-1212
AI_PROFILE=general
AI_TIMEOUT_MS=30000

# Upload limits
MAX_FILE_SIZE_MB=10
MAX_FILE_COUNT=20

# Fuzzy search: AI expansion triggered when local score is below this threshold (0–1)
AI_FUZZY_THRESHOLD=0.6
